# =============================================================================
# THE WATCH IDENTIFIER — Environment Variables
# Copy to `.env` (client) and configure Vercel project envs (server).
# NEVER commit real values. NEVER put a secret behind EXPO_PUBLIC_*.
# =============================================================================

# -------- CLIENT (bundled into the app — PUBLIC, non-secret only) ------------
# Anything prefixed EXPO_PUBLIC_ is embedded in the APK and is readable by users.
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_API_BASE_URL=https://your-vercel-app.vercel.app
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_POSTHOG_KEY=phc_xxx
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxx
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-xxx~xxx

# -------- SERVER (Vercel Functions only — SECRET, never shipped to client) ----
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
EBAY_CLIENT_ID=your-ebay-app-client-id
EBAY_CLIENT_SECRET=your-ebay-cert-id
EBAY_MARKETPLACE_ID=EBAY_US

# Supabase service role — server-side privileged access for quota & RLS bypass
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Rate limiting / server quota store (Upstash Redis free tier)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Server-side Sentry (API error monitoring)
SENTRY_DSN_SERVER=https://xxx@xxx.ingest.sentry.io/xxx
